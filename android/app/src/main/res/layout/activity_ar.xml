<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/arRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <fragment
        android:id="@+id/arFragment"
        android:name="com.google.ar.sceneform.ux.ArFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Centre aiming reticle + loading spinner -->
    <ImageView
        android:id="@+id/centerReticle"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="center"
        android:src="@drawable/ar_reticle_drawable"
        android:visibility="invisible"
        android:contentDescription="Aiming reticle" />

    <ProgressBar
        android:id="@+id/reticleLoading"
        style="?android:attr/progressBarStyle"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:visibility="invisible" />

    <!-- Compact mode selector — wrap_content, floats at top centre -->
    <LinearLayout
        android:id="@+id/modeBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="52dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="5dp"
        android:background="@drawable/ar_mode_bar_bg">

        <TextView
            android:id="@+id/plantDistanceModeButton"
            android:layout_width="118dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Plant"
            android:textColor="#F2F7F0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/ar_pill_active" />

        <Space
            android:layout_width="6dp"
            android:layout_height="1dp" />

        <TextView
            android:id="@+id/windowMeasureModeButton"
            android:layout_width="118dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="Window"
            android:textColor="#F2F7F0"
            android:textSize="13sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="@drawable/ar_pill_inactive" />
    </LinearLayout>

    <!-- Measurement card — shown after first anchor is placed -->
    <LinearLayout
        android:id="@+id/measurementCard"
        android:layout_width="210dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="128dp"
        android:background="@drawable/ar_measurement_card_bg"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:gravity="center"
        android:visibility="gone">

        <!-- Mode label -->
        <TextView
            android:id="@+id/measurementModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISTANCE"
            android:textColor="#56C17F"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:gravity="center" />

        <!-- Live distance value -->
        <TextView
            android:id="@+id/liveMeasurementBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#F4C84B"
            android:textSize="44sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="2dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#25422E"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="10dp" />

        <!-- Quality row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_gravity="center">

            <View
                android:id="@+id/measurementQualityDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/ar_confidence_dot"
                android:layout_marginEnd="7dp" />

            <TextView
                android:id="@+id/measurementQualityText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scanning…"
                android:textColor="#94B09C"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom bar — step instruction + snap / reset / confidence dot -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="28dp"
        android:background="@drawable/ar_bottom_bar_bg"
        android:orientation="vertical"
        android:paddingTop="14dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="10dp"
            android:text="Aim at the floor spot below the window."
            android:textColor="#94B09C"
            android:textSize="13sp"
            android:gravity="center"
            android:maxLines="2"
            android:ellipsize="end" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:id="@+id/resetButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_vertical|start"
                android:text="↺  Reset"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#94B09C"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp" />

            <TextView
                android:id="@+id/snapPointButton"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:gravity="center"
                android:text="+"
                android:textSize="34sp"
                android:textStyle="bold"
                android:textColor="#0B1A11"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ar_snap_button" />

            <View
                android:id="@+id/confidenceDot"
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_gravity="center_vertical|end"
                android:layout_marginEnd="10dp"
                android:background="@drawable/ar_confidence_dot" />
        </FrameLayout>
    </LinearLayout>

    <!-- Animated coach overlay: shown on entry, tap anywhere or "Got it" to dismiss -->
    <FrameLayout
        android:id="@+id/coachOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E0081109"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginStart="26dp"
            android:layout_marginEnd="26dp"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/ar_measurement_card_bg"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingTop="26dp"
            android:paddingBottom="22dp">

            <TextView
                android:id="@+id/coachTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="How to measure"
                android:textColor="#F2F7F0"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="158dp"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="14dp">

                <!-- Window mode: window icon + a tap dot that sweeps edge to edge -->
                <ImageView
                    android:id="@+id/coachWindow"
                    android:layout_width="92dp"
                    android:layout_height="92dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_window_frame"
                    android:visibility="gone"
                    android:contentDescription="Window" />

                <!-- Floor line, shown only for the sill measurement (floor-to-sill) -->
                <View
                    android:id="@+id/coachFloor"
                    android:layout_width="118dp"
                    android:layout_height="3dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:layout_marginBottom="18dp"
                    android:visibility="gone"
                    android:background="@drawable/ar_coach_floor" />

                <TextView
                    android:id="@+id/coachTapWindow"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#0B1A11"
                    android:textSize="23sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:background="@drawable/ar_coach_tap" />

                <!-- Plant mode: target ring on the floor + a plant that drops in -->
                <ImageView
                    android:id="@+id/coachRing"
                    android:layout_width="58dp"
                    android:layout_height="58dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ar_reticle_drawable"
                    android:visibility="gone"
                    android:contentDescription="Spot" />

                <ImageView
                    android:id="@+id/coachPlant"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_potted_plant"
                    android:visibility="gone"
                    android:contentDescription="Plant" />

                <TextView
                    android:id="@+id/coachTapPlant"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="bottom|center_horizontal"
                    android:gravity="center"
                    android:text="+"
                    android:textColor="#0B1A11"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:background="@drawable/ar_coach_tap" />

                <!-- Lottie animation (preferred); falls back to the vector demo
                     above if the asset is missing or fails to parse -->
                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/coachLottie"
                    android:layout_width="152dp"
                    android:layout_height="152dp"
                    android:layout_gravity="center"
                    android:visibility="gone" />
            </FrameLayout>

            <TextView
                android:id="@+id/coachSteps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#94B09C"
                android:textSize="14sp"
                android:lineSpacingExtra="5dp" />

            <TextView
                android:id="@+id/coachDismiss"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Got it"
                android:textColor="#0B1A11"
                android:textSize="15sp"
                android:textStyle="bold"
                android:paddingStart="36dp"
                android:paddingEnd="36dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/ar_pill_active" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
